{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Desktop for macOS",
  "version": "0.1.0",
  "identifier": "ai.x.grok.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Grok Desktop for macOS",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 640,
        "visible": false,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
